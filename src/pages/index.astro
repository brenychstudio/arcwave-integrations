---
import BaseLayout from "../layouts/BaseLayout.astro";
import Section from "../components/Section.astro";
import HeroBanner from "../components/HeroBanner.astro";
import ServicesGrid from "../components/ServicesGrid.astro";
import ProcessTimeline from "../components/ProcessTimeline.astro";
import TrustStrip from "../components/TrustStrip.astro";

import { site } from "../content/site";
import { services } from "../content/services";
---
<BaseLayout
  title={`${site.name} — Premium Engineering Installations`}
  description="Telecom, networks & Wi-Fi, electricity & smart home (climate control), EV charging, alarm systems + CCTV, audio & home cinema. Clean execution, documentation, support."
>
  <HeroBanner
    title="Premium engineering installations — clean, documented, supportable."
    subtitle="Telecom, networks & Wi-Fi, electricity & smart home (climate control), EV charging, alarm systems + CCTV, audio & home cinema."
    image="/hero/hero-home-01.png"
    badge={{ label: "Concept study", href: "/about" }}
    primaryCta={{ label: "Request a quote", href: "/contact#quote" }}
    secondaryCta={{ label: "View services", href: "/services" }}
  />

  <div class="container"><div class="hr"></div></div>

  <Section eyebrow="Services" title="Focus areas built for reliability">
    <ServicesGrid services={services} />
  </Section>

  <Section eyebrow="Process" title="A clear workflow" note="Survey → Proposal → Installation → Support">
    <ProcessTimeline steps={site.processSteps} />
  </Section>

  <Section eyebrow="Trust" title="Straightforward commitments">
    <TrustStrip badges={site.trustBadges} />
  </Section>
</BaseLayout>
