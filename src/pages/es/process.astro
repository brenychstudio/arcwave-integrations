---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroBanner from "../../components/HeroBanner.astro";
import Section from "../../components/Section.astro";
import ProcessTimeline from "../../components/ProcessTimeline.astro";
import { siteEs } from "../../content/site.es";
---

<BaseLayout
  title={`Proceso — ${siteEs.name}`}
  description="Un flujo claro: visita, propuesta, instalación, soporte. Alcance y limitaciones definidos desde el inicio."
>
  <HeroBanner
    title="Proceso"
    subtitle="Un flujo claro: visita, propuesta, instalación, soporte. Definimos alcance y limitaciones desde el inicio para evitar sorpresas."
    image="/hero/hero-home-01.png"
    variant="compact"
    primaryCta={{ label: "Solicitar presupuesto", href: "/es/contact#quote" }}
    secondaryCta={{ label: "Servicios", href: "/es/services" }}
  />

  <div class="container"><div class="hr"></div></div>

  <Section eyebrow="Flujo" title="De brief a entrega" note="Diseñado para un resultado limpio y mantenible.">
    <ProcessTimeline steps={siteEs.processSteps} />
  </Section>

  <Section eyebrow="Entrega" title="Qué entregamos" note="Lo esencial para operar y mantener el sistema.">
    <div class="grid3">
      <div class="card box">
        <div class="k">Etiquetas</div>
        <div class="p">Etiquetado claro y rutas ordenadas para un soporte eficiente.</div>
      </div>
      <div class="card box">
        <div class="k">Notas as-built</div>
        <div class="p">Qué se instaló, dónde y cómo quedó configurado (según alcance).</div>
      </div>
      <div class="card box">
        <div class="k">Recomendaciones</div>
        <div class="p">Sugerencias prácticas para uso diario y futuras ampliaciones.</div>
      </div>
    </div>
  </Section>

  <Section eyebrow="Inicio" title="Empezamos con un brief corto">
    <div class="card box ctaBox">
      <div>
        <div class="k">Siguiente paso</div>
        <div class="p">Cuéntanos qué necesitas y cualquier limitación de acceso/horarios.</div>
      </div>
      <a class="cta" href="/es/contact#quote">Solicitar presupuesto →</a>
    </div>
  </Section>

  <style>
    .box{ padding: 18px; border-radius: var(--radius); }
    .k{
      font-size: 12px;
      letter-spacing:.16em;
      text-transform:uppercase;
      color: var(--muted2);
      font-weight: 520;
    }
    .p{
      margin-top: 6px;
      color: var(--muted);
      font-size: 13px;
      line-height: 1.65;
      font-weight: 420;
    }
    .grid3{
      display:grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 14px;
      align-items: stretch;
    }
    .ctaBox{
      display:flex;
      align-items:center;
      justify-content:space-between;
      gap: 14px;
    }
    .cta{
      display:inline-flex; align-items:center; justify-content:center;
      padding: 12px 16px; border-radius: 999px;
      border: 1px solid rgba(10,132,255,.35);
      background: rgba(10,132,255,.10);
      font-weight: 650;
      letter-spacing: .008em;
      text-decoration:none; color: var(--text);
      box-shadow: 0 10px 24px rgba(10,10,20,.06);
      white-space: nowrap;
      transition: transform .12s ease, box-shadow .12s ease, background .12s ease;
    }
    .cta:hover{
      transform: translateY(-1px);
      box-shadow: 0 14px 30px rgba(10,10,20,.08);
      background: rgba(10,132,255,.12);
    }
    @media (max-width: 980px){
      .grid3{ grid-template-columns: 1fr; }
      .ctaBox{ flex-direction: column; align-items: stretch; }
      .cta{ width: 100%; }
    }
  </style>
</BaseLayout>
