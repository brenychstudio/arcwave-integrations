---
import type { Service } from "../content/services";
import { baseFromLang, langFromPath, t } from "../content/i18n";

const { services, showQuote = false } = Astro.props as {
  services: Service[];
  showQuote?: boolean;
};

const lang = langFromPath(Astro.url.pathname);
const base = baseFromLang(lang);

const viewDetails = t(lang, "View details →", "Ver detalles →");
const requestQuote = t(lang, "Request a quote", "Solicitar presupuesto");
---

<div class="grid">
  {services.map((s) => {
    const detailsHref = `${base}/services/${s.key}`;
    const quoteHref = `${base}/contact?service=${s.key}#quote`;
    const aria = t(lang, `Open ${s.title} details`, `Abrir detalles de ${s.title}`);

    return (
      <article class="card item">
        <a class="stretched" href={detailsHref} aria-label={aria} data-vt="1"></a>

        <div class="content">
          <div class="top">
            <div class="iconWrap" aria-hidden="true">
              <img class="icon" src={s.icon} alt="" loading="lazy" decoding="async" />
            </div>
            <div class="meta">
              <h3 class="t">{s.title}</h3>
              <p class="d">{s.short}</p>
            </div>
          </div>

          <div class="thumb">
            <img class="bg" src={s.cardImage} alt="" loading="lazy" decoding="async" />
            <img class="fg" src={s.cardImage} alt="" loading="lazy" decoding="async" />
          </div>
        </div>

        <div class="actions">
          <a class="more" href={detailsHref} data-vt="1">{viewDetails}</a>
          {showQuote && (
            <a class="quote" href={quoteHref} data-vt="1">{requestQuote}</a>
          )}
        </div>
      </article>
    );
  })}
</div>

<style>
  .grid{
    display:grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  .item{
    position: relative;
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 16px;
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform .18s ease, border-color .18s ease, background .18s ease;
  }

  .item:hover{
    transform: translateY(-2px);
    border-color: rgba(10,132,255,.14);
    background: rgba(255,255,255,.82);
  }

  .stretched{
    position: absolute;
    inset: 0;
    border-radius: inherit;
    z-index: 2;
    background: transparent;
  }

  .content{
    position: relative;
    z-index: 1;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .actions{
    position: relative;
    z-index: 3;
    margin-top: auto;
    padding-top: 12px;
    display:flex;
    align-items:center;
    justify-content: space-between;
    gap: 10px;
  }

  .top{ display:flex; gap: 12px; align-items:flex-start; }

  .iconWrap{
    width: 44px;
    height: 44px;
    border-radius: 16px;
    border: 1px solid var(--border2);
    background: rgba(255,255,255,.65);
    display:flex;
    align-items:center;
    justify-content:center;
    flex: 0 0 auto;
  }

  .icon{
    width: 44px;
  height: 44px;
  border-radius: 16px;
    object-fit: contain;
    display: block;
  }

  .t{
    font-size: 16px;
    letter-spacing:-.01em;
    margin:0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .d{
    font-size: 13px;
    color: var(--muted);
    margin:6px 0 0;
    line-height:1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    min-height: 3em;
  }

  .thumb{
    margin-top: 14px;
    border-radius: 14px;
    overflow:hidden;
    border:1px solid var(--border2);
    background: transparent;

    position: relative;
    aspect-ratio: 16 / 10;
    box-shadow:
      inset 0 1px 0 rgba(255,255,255,.70),
      inset 0 -1px 0 rgba(0,0,0,.04);
  }

  .thumb:after{
    content:"";
    position:absolute;
    inset:0;
    pointer-events:none;
    border-radius: inherit;

    background:
      linear-gradient(180deg, rgba(255,255,255,.22), rgba(255,255,255,0) 35%),
      radial-gradient(120% 100% at 50% 0%, rgba(255,255,255,.10), rgba(255,255,255,0) 55%),
      radial-gradient(120% 120% at 50% 120%, rgba(0,0,0,.06), rgba(0,0,0,0) 55%);
    mix-blend-mode: soft-light;
    opacity: .9;
  }

  .thumb .bg{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;

    filter: blur(18px);
    opacity: .20;
    transform: scale(1.10);
  }

  .thumb .fg{
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: translateZ(0) scale(1.01);
    transition: transform .22s ease;
  }

  .item:hover .thumb .fg{
    transform: translateZ(0) scale(1.02);
  }

  .item:hover .thumb:after{
    opacity: 1;
  }

  .more{
    font-weight:600;
    font-size: 13px;
    color: var(--muted);
  }
  .item:hover .more{ color: var(--text); }

  .quote{
    display:inline-flex;
    align-items:center;
    justify-content:center;
    padding: 8px 12px;
    border-radius: 999px;
    border: 1px solid rgba(10,132,255,.30);
    background: rgba(10,132,255,.08);
    font-weight: 800;
    font-size: 12px;
    white-space: nowrap;
    box-shadow: 0 10px 24px rgba(10,10,20,.06);
    transition: background .18s ease, border-color .18s ease, transform .18s ease;
  }
  .quote:hover{
    background: rgba(10,132,255,.12);
    border-color: rgba(10,132,255,.40);
    transform: translateY(-1px);
  }

  @media (max-width: 1100px){
    .grid{ grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 980px){
    .grid{ grid-template-columns: 1fr; }
    .actions{ flex-direction: column; align-items: stretch; }
    .quote{ width: 100%; }
  }
</style>
