---
import { langFromPath, t } from "../content/i18n";

type Props = {
  title: string;
  subtitle: string;
  image: string;
  overlay?: string;
  primaryCta: { label: string; href: string };
  secondaryCta: { label: string; href: string };
  variant?: "default" | "compact";
  badge?: { label: string; href?: string };
};

const { title, subtitle, image, overlay, primaryCta, secondaryCta, variant = "default", badge } = Astro.props as Props;

const lang = langFromPath(Astro.url.pathname);
const pillTag = t(lang, "Concept visuals", "Visuales de concepto");
const pillNote = t(lang, "Illustrative only — no fake projects", "Solo ilustrativo — sin proyectos ficticios");
---

<section class={`hero ${variant === "compact" ? "compact" : ""}`.trim()}>
  <div class="container grid">
    <div class="copy">
      {badge ? (
        badge.href ? (
          <a class="demoEyebrow" href={badge.href} data-vt="1">{badge.label}</a>
        ) : (
          <div class="demoEyebrow">{badge.label}</div>
        )
      ) : null}

      <h1 class="h">{title}</h1>
      <p class="p">{subtitle}</p>

      <div class="actions">
        <a class="btn primary" href={primaryCta.href} data-vt={primaryCta.href.startsWith("/") ? "1" : undefined}>
          {primaryCta.label}
        </a>

        <a class="btn" href={secondaryCta.href} data-vt={secondaryCta.href.startsWith("/") ? "1" : undefined}>
          {secondaryCta.label}
        </a>
      </div>
    </div>

    <div class="media card">
      <img src={image} alt="" loading="eager" decoding="async" />
      {overlay && <img class="overlay" src={overlay} alt="" loading="eager" decoding="async" />}
      <div class="shade"></div>
    </div>
  </div>
</section>

<style>
  .hero{ padding: 44px 0 18px; }
  .hero.compact{ padding: 34px 0 10px; }

  .grid{
    display:grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 26px;
    align-items:center;
  }

  .copy{ display:flex; flex-direction:column; gap: 12px; }

  .demoEyebrow{
    display:inline-flex;
    align-items:center;
    justify-content:center;

    padding: 8px 12px;
    border-radius: 999px;

    border: 1px solid rgba(15,15,20,.10);
    background: rgba(255,255,255,.58);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);

    font-size: 12px;
    letter-spacing: .18em;
    text-transform: uppercase;
    color: var(--muted2);
    width: fit-content;
  }

  a.demoEyebrow:hover{
    color: var(--text);
    border-color: rgba(10,132,255,.18);
    background: rgba(10,132,255,.05);
  }

  .pill{
    display:inline-flex; align-items:center; gap:10px;
    padding: 10px 12px; border-radius:999px;
    border:1px solid var(--border2); background:rgba(255,255,255,.65);
    width: fit-content;
  }

  .tag{
    font-size:12px; letter-spacing:.14em; text-transform:uppercase;
    color: var(--muted);
  }
  .small{ font-size: 13px; color: var(--muted2); }

  .h{ font-size: clamp(34px, 4vw, 56px); line-height: 1.02; }
  .hero.compact .h{ font-size: clamp(32px, 3.2vw, 46px); }

  .p{ font-size: 16px; max-width: 56ch; }

  .actions{ display:flex; gap: 12px; flex-wrap:wrap; margin-top: 6px; }

  .media{
    position:relative;
    overflow:hidden;
    border-radius: var(--radius2);
    min-height: 320px;
  }

  .hero.compact .media{
    min-height: 240px;
    height: clamp(240px, 32vh, 380px);
  }

  .media img{ width:100%; height:100%; object-fit:cover; }

  .overlay{
    position:absolute; inset:0;
    opacity:.40;
    mix-blend-mode: overlay;
    pointer-events:none;
  }

  .shade{
    position:absolute; inset:0;
    background: radial-gradient(700px 420px at 20% 0%, rgba(255,255,255,.28), transparent 60%);
    pointer-events:none;
  }

  @media (max-width: 980px){
    .grid{ grid-template-columns: 1fr; }
    .media{ min-height: 260px; }
    .hero.compact .media{ height: clamp(220px, 30vh, 320px); }
  }
</style>
